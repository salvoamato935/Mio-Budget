<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Budget Familiare V2</title>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#121214">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-weight/6.4.2/css/all.min.css">
    <style>
        :root {
            --bg-color: #121214;
            --card-bg: #1a1a1e;
            --accent: #6366f1;
            --accent-gradient: linear-gradient(135deg, #4f46e5, #6366f1);
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --fisse: #3b82f6;
            --variabili: #10b981;
            --svago: #f59e0b;
            --danger: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            padding-bottom: 90px;
            overflow-x: hidden;
        }

        header {
            background: var(--card-bg);
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid #2a2a30;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        header h1 {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .container {
            padding: 20px;
            max-width: 500px;
            margin: 0 auto;
        }

        .view {
            display: none;
        }

        .view.active {
            display: block;
        }

        /* CARD BUDGET PRINCIPALE */
        .main-card {
            background: var(--accent-gradient);
            border-radius: 24px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(79, 70, 229, 0.2);
            margin-bottom: 25px;
            position: relative;
            overflow: hidden;
        }

        .main-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
            pointer-events: none;
        }

        .main-card p {
            font-size: 14px;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .main-card h2 {
            font-size: 38px;
            font-weight: 800;
            margin-bottom: 15px;
        }

        .progress-bar-container {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            height: 8px;
            width: 100%;
            overflow: hidden;
        }

        .progress-bar {
            background: #fff;
            height: 100%;
            width: 0%;
            transition: width 0.5s ease;
        }

        .budget-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 25px;
        }

        .mini-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 15px;
            border: 1px solid #2a2a30;
        }

        .mini-card span {
            font-size: 12px;
            color: var(--text-muted);
            display: block;
            margin-bottom: 4px;
        }

        .mini-card p {
            font-size: 18px;
            font-weight: 700;
        }

        /* SEZIONE CASSETTI */
        .section-title {
            font-size: 16px;
            color: var(--text-muted);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
        }

        .cassetto-row {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid #2a2a30;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .cassetto-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .cassetto-name {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
        }

        .cassetto-icon {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 14px;
        }

        .cassetto-amounts {
            text-align: right;
        }

        .cassetto-dispo {
            font-size: 16px;
            font-weight: 700;
        }

        .cassetto-tot {
            font-size: 12px;
            color: var(--text-muted);
        }

        .cassetto-progress {
            height: 6px;
            background: #2a2a30;
            border-radius: 4px;
            overflow: hidden;
        }

        .cassetto-progress-bar {
            height: 100%;
            width: 0%;
            transition: width 0.5s ease;
        }

        /* ULTIME SPESE */
        .spesa-item {
            background: var(--card-bg);
            border-radius: 14px;
            padding: 12px 16px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #2a2a30;
        }

        .spesa-info h4 {
            font-size: 15px;
            font-weight: 600;
        }

        .spesa-info span {
            font-size: 11px;
            color: var(--text-muted);
        }

        .spesa-amount {
            font-weight: 700;
            color: var(--danger);
        }

        /* PULSANTINI AGGIUNTA */
        .btn {
            background: var(--accent-gradient);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 16px;
            font-weight: 600;
            font-size: 16px;
            width: 100%;
            cursor: pointer;
            margin-top: 10px;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        }

        .btn-secondary {
            background: #2a2a30;
            color: var(--text-main);
            box-shadow: none;
            margin-top: 20px;
        }

        /* FORM DI INSERIMENTO */
        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 6px;
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            background: #1a1a1e;
            border: 1px solid #2a2a30;
            padding: 14px;
            border-radius: 14px;
            color: white;
            font-size: 16px;
            outline: none;
        }

        .form-control:focus {
            border-color: var(--accent);
        }

        /* COSTRUZIONE SALVADANAI */
        .salva-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 20px;
            border: 1px solid #2a2a30;
            margin-bottom: 15px;
        }

        .salva-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .salva-title {
            font-weight: 700;
            font-size: 16px;
        }

        .salva-money {
            font-weight: 800;
            color: var(--variabili);
        }

        /* CONFIGURAZIONE INIZIALE STRUTTURA */
        .setup-box {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 20px;
            border: 1px solid #2a2a30;
            text-align: center;
        }

        /* NAVIGAZIONE IN BASSO FIXED */
        .nav-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 75px;
            background: rgba(26, 26, 30, 0.95);
            backdrop-filter: blur(10px);
            border-top: 1px solid #2a2a30;
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 1000;
            padding-bottom: env(safe-area-inset-bottom);
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 11px;
            font-weight: 500;
            gap: 4px;
            background: none;
            border: none;
            cursor: pointer;
            width: 60px;
        }

        .nav-item i {
            font-size: 20px;
        }

        .nav-item.active {
            color: var(--accent);
        }

        .nav-center-btn {
            width: 54px;
            height: 54px;
            background: var(--accent-gradient);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 22px;
            box-shadow: 0 4px 15px rgba(79, 70, 229, 0.4);
            transform: translateY(-15px);
            border: none;
            cursor: pointer;
        }

        /* MODALE POPUP */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.7);
            z-index: 2000;
            align-items: flex-end;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: var(--card-bg);
            width: 100%;
            border-top-left-radius: 28px;
            border-top-right-radius: 28px;
            padding: 25px;
            padding-bottom: calc(25px + env(safe-area-inset-bottom));
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
        }
    </style>
</head>
<body>

    <header>
        <h1 id="header-title">Budget Familiare 🏠</h1>
    </header>

    <div class="container">
        
        <!-- SCHERMATA SETUP INIZIALE -->
        <div id="view-setup" class="view">
            <div class="setup-box">
                <i class="fa-solid from-neutral fa-wallet style-icon" style="font-size: 40px; color: var(--accent); margin-bottom: 15px;"></i>
                <h3 style="margin-bottom: 10px;">Configura il Budget di Casa</h3>
                <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 20px;">Non ci sono budget impostati. Inserisci le entrate totali per iniziare la pianificazione familiare.</p>
                
                <div class="form-group" style="text-align: left;">
                    <label>Entrate Totali Mensili (€)</label>
                    <input type="number" id="setup-totale" class="form-control" placeholder="Es. 2500" inputmode="decimal">
                </div>
                <button class="btn" onclick="inizializzaBudget()">Attiva Budget Condiviso</button>
            </div>
        </div>

        <!-- SCHERMATA DASHBOARD -->
        <div id="view-home" class="view active">
            <div class="main-card">
                <p>Budget Disponibile Totale</p>
                <h2 id="dash-disponibile">0,00 €</h2>
                <div class="progress-bar-container">
                    <div id="dash-progress" class="progress-bar"></div>
                </div>
            </div>

            <div class="budget-details">
                <div class="mini-card">
                    <span>Entrate Mensili</span>
                    <p id="dash-entrate" style="color: var(--variabili);">0,00 €</p>
                </div>
                <div class="mini-card">
                    <span>Totale Speso</span>
                    <p id="dash-speso" style="color: var(--danger);">0,00 €</p>
                </div>
            </div>

            <h3 class="section-title">I Cassetti di Spesa</h3>
            <div id="cassetti-container">
                <!-- Generati dinamicamente via JS -->
            </div>

            <h3 class="section-title" style="margin-top: 20px;">Ultime Spese di Casa</h3>
            <div id="spese-container">
                <!-- Generate dinamicamente via JS -->
            </div>
            
            <button class="btn btn-secondary" onclick="resetCompleto()">🔄 Reset/Nuovo Mese</button>
        </div>

        <!-- SCHERMATA SALVADANAI -->
        <div id="view-salvadanai" class="view">
            <h3 class="section-title">Obiettivi di Risparmio</h3>
            <div id="salvadanai-container">
                <!-- Generati dinamicamente via JS -->
            </div>
            <button class="btn" onclick="openModal('modal-salvadanaio')"><i class="fa-solid fa-plus"></i> Nuovo Salvadanai</button>
        </div>

    </div>

    <!-- NAVBAR IN BASSO FIXED -->
    <nav class="nav-bar" id="app-nav" style="display:none;">
        <button class="nav-item active" onclick="switchView('home', this)">
            <i class="fa-solid fa-house"></i>
            <span>Home</span>
        </button>
        <button class="nav-center-btn" onclick="openModal('modal-spesa')">
            <i class="fa-solid fa-plus"></i>
        </button>
        <button class="nav-item" onclick="switchView('salvadanai', this)">
            <i class="fa-solid fa-piggy-bank"></i>
            <span>Risparmi</span>
        </button>
    </nav>

    <!-- MODALE AGGIUNGI SPESA -->
    <div id="modal-spesa" class="modal" onclick="closeModalOnBackdrop(event)">
        <div class="modal-content">
            <h3 style="margin-bottom: 20px;">Registra Spesa</h3>
            <div class="form-group">
                <label>Importo (€)</label>
                <input type="number" id="spesa-importo" class="form-control" placeholder="0.00" step="0.01" inputmode="decimal">
            </div>
            <div class="form-group">
                <label>Descrizione / Negozio</label>
                <input type="text" id="spesa-desc" class="form-control" placeholder="Es. Spesa Conad, Benzina...">
            </div>
            <div class="form-group">
                <label>Cassetto di Spesa</label>
                <select id="spesa-cassetto" class="form-control">
                    <option value="fisse">🏠 Spese Fisse (Bollette, Mutuo, Rate)</option>
                    <option value="variabili">🛒 Spese Variabili (Cibo, Carburante, Spesa)</option>
                    <option value="svago">🎉 Svago e Coccole (Ristoranti, Shopping)</option>
                </select>
            </div>
            <button class="btn" onclick="aggiungiSpesa()">Salva Spesa</button>
        </div>
    </div>

    <!-- MODALE AGGIUNGI SALVADANAIO -->
    <div id="modal-salvadanaio" class="modal" onclick="closeModalOnBackdrop(event)">
        <div class="modal-content">
            <h3 style="margin-bottom: 20px;">Nuovo Obiettivo di Risparmio</h3>
            <div class="form-group">
                <label>Nome Obiettivo</label>
                <input type="text" id="salva-nome" class="form-control" placeholder="Es. Fondo Auto, Vacanze...">
            </div>
            <div class="form-group">
                <label>Cifra Target (€)</label>
                <input type="number" id="salva-target" class="form-control" placeholder="Es. 1000" inputmode="decimal">
            </div>
            <button class="btn" onclick="creaSalvadanaio()">Crea Salvadanaio</button>
        </div>
    </div>

    <!-- SCRIPT CONFIGURAZIONE ED ELABORAZIONE DATI FIREBASE -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getDatabase, ref, set, onValue, push } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

        // CONFIGURAZIONE REALE OTTENUTA DAL TUO ACCOUNT FIREBASE
        const firebaseConfig = {
            apiKey: "AIzaSyA7UCnGi06p1HPhRPgS4LyXcbKx_LhdOsM",
            authDomain: "budget-casa-7eead.firebaseapp.com",
            databaseURL: "https://budget-casa-7eead-default-rtdb.firebaseio.com/",
            projectId: "budget-casa-7eead",
            storageBucket: "budget-casa-7eead.firebasestorage.app",
            messagingSenderId: "529644674685",
            appId: "1:529644674685:web:93438c7393631bc7d4db14"
        };

        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app);
        const budgetRef = ref(db, 'budget_familiare');

        // Stato Locale Globale applicazione
        let appData = {
            entrate: 0,
            cassetti: { fisse: 0, variabili: 0, svago: 0 },
            spese: {},
            salvadanai: {}
        };

        // Funzione per Inizializzare il Budget (Buste 50/30/20 Automatico)
        window.inizializzaBudget = function() {
            const entrateInput = parseFloat(document.getElementById('setup-totale').value);
            if (!entrateInput || entrateInput <= 0) return alert("Inserisci una cifra valida!");

            // Calcolo automatico della ripartizione ideale
            appData.entrate = entrateInput;
            appData.cassetti = {
                fisse: Math.round(entrateInput * 0.50),      // 50% Spese Fisse
                variabili: Math.round(entrateInput * 0.30),  // 30% Spese Variabili
                svago: Math.round(entrateInput * 0.20)      // 20% Svago e Risparmio
            };
            appData.spese = {};

            set(budgetRef, appData).then(() => {
                switchView('home');
            });
        }

        // Funzione per Inserire Spesa in tempo reale
        window.aggiungiSpesa = function() {
            const importo = parseFloat(document.getElementById('spesa-importo').value);
            const desc = document.getElementById('spesa-desc').value.trim();
            const cassetto = document.getElementById('spesa-cassetto').value;

            if (!importo || importo <= 0 || !desc) return alert("Compila tutti i campi!");

            const nuoveSpeseRef = ref(db, 'budget_familiare/spese');
            const nuovaSpesaPush = push(nuoveSpeseRef);
            
            set(nuovaSpesaPush, {
                importo: importo,
                desc: desc,
                cassetto: cassetto,
                data: new Date().toLocaleDateString('it-IT', {day: '2-digit', month: '2-digit', hour: '2-digit', minute:'2-digit'})
            }).then(() => {
                closeModal('modal-spesa');
                document.getElementById('spesa-importo').value = '';
                document.getElementById('spesa-desc').value = '';
            });
        }

        // Crea Nuovo Obiettivo Salvadanaio
        window.creaSalvadanaio = function() {
            const nome = document.getElementById('salva-nome').value.trim();
            const target = parseFloat(document.getElementById('salva-target').value);

            if (!nome || !target || target <= 0) return alert("Compila tutti i campi correttamente!");

            const salvaRef = ref(db, 'budget_familiare/salvadanai');
            const nuovoSalvaPush = push(salvaRef);

            set(nuovoSalvaPush, {
                nome: nome,
                target: target,
                attuale: 0
            }).then(() => {
                closeModal('modal-salvadanaio');
                document.getElementById('salva-nome').value = '';
         
